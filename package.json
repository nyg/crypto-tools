{
   "name": "crypto-tools",
   "version": "0.0.6",
   "description": "miscellaneous cryptocurrency tools (formerly binance-staking-overview).",
   "main": "electron/main.cjs",
   "repository": {
      "type": "git",
      "url": "git+ssh://git@github.com/nyg/crypto-tools.git"
   },
   "keywords": [
      "crypto",
      "binance",
      "staking",
      "overview",
      "dashboard"
   ],
   "author": "nyg",
   "packageManager": "pnpm@11.0.9",
   "license": "MIT",
   "bugs": {
      "url": "https://github.com/nyg/crypto-tools/issues"
   },
   "scripts": {
      "dev": "next dev",
      "debug": "NODE_OPTIONS='--inspect' next dev",
      "mocked": "NEXT_PUBLIC_MOCK_DATA=true pnpm dev",
      "build": "next build",
      "start": "next start",
      "lint": "eslint . --fix",
      "electron:dev": "npx electron .",
      "electron:build": "next build && node scripts/copy-static.cjs && electron-builder --publish never"
   },
   "dependencies": {
      "@ai-sdk/anthropic": "3.0.71",
      "ai": "6.0.168",
      "big.js": "7.0.1",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "date-fns": "4.1.0",
      "got": "15.0.3",
      "lucide-react": "1.12.0",
      "modern-dijkstra": "1.1.2",
      "next": "16.2.4",
      "next-themes": "0.4.6",
      "postgres": "3.4.9",
      "qs": "6.15.1",
      "radix-ui": "1.4.3",
      "react": "19.2.5",
      "react-day-picker": "10.0.0",
      "react-dom": "19.2.5",
      "recharts": "3.8.1",
      "shadcn": "4.6.0",
      "sonner": "2.0.7",
      "swr": "2.4.1",
      "tailwind-merge": "3.5.0",
      "tw-animate-css": "1.4.0",
      "zod": "4.3.6"
   },
   "devDependencies": {
      "@tailwindcss/postcss": "4.2.4",
      "electron": "41.3.0",
      "electron-builder": "26.8.1",
      "eslint": "9.39.4",
      "eslint-config-next": "16.2.4",
      "postcss": "8.5.12",
      "tailwindcss": "4.2.4"
   },
   "build": {
      "appId": "com.nyg.crypto-tools",
      "productName": "CryptoTools",
      "asar": true,
      "npmRebuild": false,
      "files": [
         "electron/**/*"
      ],
      "extraResources": [
         {
            "from": ".next/standalone",
            "to": "next-app",
            "filter": [
               "**/*"
            ]
         },
         {
            "from": ".next/standalone/node_modules",
            "to": "next-app/node_modules"
         }
      ],
      "asarUnpack": [
         "resources/next-app/**"
      ],
      "mac": {
         "target": [
            {
               "target": "dmg"
            }
         ],
         "category": "public.app-category.finance"
      },
      "win": {
         "target": [
            {
               "target": "nsis"
            }
         ],
         "artifactName": "${productName}-${version}-setup.${ext}"
      },
      "linux": {
         "target": [
            {
               "target": "AppImage"
            }
         ]
      }
   }
}
