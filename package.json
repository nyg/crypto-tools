{
   "name": "crypto-tools",
   "version": "0.0.10",
   "description": "miscellaneous cryptocurrency tools (formerly binance-staking-overview).",
   "type": "module",
   "repository": {
      "type": "git",
      "url": "git+ssh://git@github.com/nyg/crypto-tools.git"
   },
   "keywords": [
      "crypto",
      "binance",
      "staking",
      "overview",
      "dashboard"
   ],
   "author": "nyg",
   "packageManager": "bun@1.2.16",
   "license": "MIT",
   "bugs": {
      "url": "https://github.com/nyg/crypto-tools/issues"
   },
   "scripts": {
      "dev": "concurrently -n vite,bun -c cyan,magenta \"vite\" \"bun --watch src/server/index.js\"",
      "dev:vite": "vite",
      "dev:server": "bun --watch src/server/index.js",
      "desktop:dev": "bunx electrobun dev --watch",
      "mocked": "VITE_MOCK_DATA=true vite",
      "build": "vite build",
      "build:stable": "bunx electrobun build --env=stable",
      "start": "NODE_ENV=production bun src/server/index.js",
      "lint": "eslint src --fix"
   },
   "dependencies": {
      "@ai-sdk/anthropic": "3.0.81",
      "ai": "6.0.196",
      "big.js": "7.0.1",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "date-fns": "4.4.0",
      "hono": "4.12.25",
      "lucide-react": "1.17.0",
      "modern-dijkstra": "1.1.2",
      "next-themes": "0.4.6",
      "qs": "6.15.2",
      "radix-ui": "1.4.3",
      "react": "19.2.7",
      "react-day-picker": "10.0.1",
      "react-dom": "19.2.7",
      "react-router": "7.17.0",
      "recharts": "3.8.1",
      "shadcn": "4.10.0",
      "sonner": "2.0.7",
      "swr": "2.4.1",
      "tailwind-merge": "3.6.0",
      "tw-animate-css": "1.4.0",
      "zod": "4.4.3"
   },
   "devDependencies": {
      "@tailwindcss/vite": "4.3.0",
      "@vitejs/plugin-react": "6.0.2",
      "concurrently": "10.0.3",
      "electrobun": "1.18.1",
      "eslint": "10.4.1",
      "eslint-plugin-react-hooks": "7.1.1",
      "globals": "17.6.0",
      "tailwindcss": "4.3.0",
      "vite": "8.0.16"
   }
}
